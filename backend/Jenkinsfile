pipeline {
  agent { label 'local-docker-builder' }

  options {
    skipDefaultCheckout(true)
    disableConcurrentBuilds()
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  // Trigger: Generic Webhook Trigger (configured in casc.yml)
  // GitHub push → Cloudflare Tunnel → Jenkins → injects GIT_REF

  environment {
    BACKEND_IMAGE = 'nonameaaaa/healytics_backend'
    BACKEND_MIGRATION_IMAGE = 'nonameaaaa/healytics_backend-migrate'
    // Ephemeral Node.js image for test/build — no Node installed in the agent.
    NODE_IMAGE = 'node:22'
    VPS_DEPLOY_SCRIPT = '/opt/healytics/dockers/scripts/deploy-backend.sh'
  }

  stages {
    // The host source tree is bind-mounted into the workspace by docker-compose
    // (HEALYTICS_REPO_PATH → /home/jenkins/agent/workspace/healytics-backend).
    // No git clone needed — just read metadata from the existing repo.
    stage('Prepare') {
      steps {
        script {
          def ref = env.GIT_REF ?: 'refs/heads/main'
          env.ACTIVE_BRANCH = ref.replaceFirst(/^refs\/heads\//, '')

          // Read commit SHA from the mounted git repo
          env.GIT_COMMIT_SHORT = sh(
            returnStdout: true,
            script: 'git rev-parse --short=12 HEAD'
          ).trim()

          env.IMAGE_TAG = env.GIT_COMMIT_SHORT

          // Host-side path for docker-run volume mounts (resolved by Docker daemon).
          // HEALYTICS_REPO_PATH is injected by docker-compose.
          env.BACKEND_HOST_DIR = "${env.HEALYTICS_REPO_PATH}/backend"

          echo "Branch: ${env.ACTIVE_BRANCH} | Commit: ${env.GIT_COMMIT_SHORT} | Tag: ${env.IMAGE_TAG}"
          echo "Backend host dir: ${env.BACKEND_HOST_DIR}"
        }
      }
    }

    stage('Resolve Deploy Target') {
      steps {
        script {
          env.VPS_SSH_HOST = sh(returnStdout: true, script: 'printf "%s" "${HEALYTICS_VPS_HOST:-}"').trim()
          env.VPS_SSH_USER = sh(returnStdout: true, script: 'printf "%s" "${HEALYTICS_VPS_SSH_USER:-deploy}"').trim()

          if (!env.VPS_SSH_HOST) {
            error('Set HEALYTICS_VPS_HOST in the local Jenkins agent environment before deploying.')
          }
        }
      }
    }

    stage('Test') {
      steps {
        // Run tests inside an ephemeral Node.js container (sibling container via host docker.sock).
        // A named volume overlays node_modules so we don't overwrite the host's
        // macOS-native modules with Linux binaries, and it caches across builds.
        sh '''
          set -eu
          docker run --rm \
            -v "${BACKEND_HOST_DIR}:/app" \
            -v healytics_backend_node_modules:/app/node_modules \
            -w /app \
            "${NODE_IMAGE}" \
            sh -c 'corepack enable || true && yarn install --frozen-lockfile && yarn test --runInBand'
        '''
      }
    }

    stage('Build') {
      steps {
        // The multi-stage Dockerfile handles yarn install + yarn build internally.
        // Just run docker build against the host source tree.
        dir('backend') {
          sh '''
            set -eu
            docker build --target runtime -t "${BACKEND_IMAGE}:${IMAGE_TAG}" .
            docker build --target migrate -t "${BACKEND_MIGRATION_IMAGE}:${IMAGE_TAG}" .
          '''
        }
      }
    }

    stage('Push') {
      steps {
        dir('backend') {
          sh "scripts/docker-push.sh ${IMAGE_TAG} ${BACKEND_IMAGE} ${BACKEND_MIGRATION_IMAGE}"
        }
      }
    }

    stage('Deploy VPS') {
      steps {
        sh '''
          set -eu
          ssh -o BatchMode=yes \
              -o StrictHostKeyChecking=accept-new \
              "${VPS_SSH_USER}@${VPS_SSH_HOST}" \
            "BACKEND_IMAGE='${BACKEND_IMAGE}' BACKEND_MIGRATION_IMAGE='${BACKEND_MIGRATION_IMAGE}' '${VPS_DEPLOY_SCRIPT}' '${IMAGE_TAG}'"
        '''
      }
    }
  }

  post {
    success {
      echo "Deployed ${BACKEND_IMAGE}:${IMAGE_TAG}"
    }
  }
}
