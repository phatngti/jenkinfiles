pipeline {
  agent { label 'local-docker-builder' }

  options {
    skipDefaultCheckout(true)
    disableConcurrentBuilds()
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  // Trigger: Generic Webhook Trigger (configured in casc.yml)
  // GitHub push → Cloudflare Tunnel → Jenkins → injects GIT_REF

  environment {
    PANEL_IMAGE = 'nonameaaaa/healytics_panel'
    // Ephemeral Flutter SDK image for test/build — no Flutter installed in the agent.
    FLUTTER_IMAGE = 'ghcr.io/cirruslabs/flutter:stable'
    VPS_DEPLOY_SCRIPT = '/opt/healytics/dockers/scripts/deploy-panel.sh'
  }

  stages {
    // The host source tree is bind-mounted into the workspace by docker-compose
    // (HEALYTICS_REPO_PATH → /home/jenkins/agent/workspace/healytics-backend).
    // No git clone needed — just read metadata from the existing repo.
    stage('Prepare') {
      steps {
        script {
          def ref = env.GIT_REF ?: 'refs/heads/main'
          env.ACTIVE_BRANCH = ref.replaceFirst(/^refs\/heads\//, '')

          // Read commit SHA from the mounted git repo
          env.GIT_COMMIT_SHORT = sh(
            returnStdout: true,
            script: 'git rev-parse --short=12 HEAD'
          ).trim()

          env.IMAGE_TAG = env.GIT_COMMIT_SHORT

          // Host-side path for docker-run volume mounts (resolved by Docker daemon).
          // HEALYTICS_REPO_PATH is injected by docker-compose.
          // Mount the entire healytic_fe workspace so admin_panel can resolve
          // its path dependency on ../common.
          env.FE_WORKSPACE_HOST_DIR = "${env.HEALYTICS_REPO_PATH}/healytic_fe"

          echo "Branch: ${env.ACTIVE_BRANCH} | Commit: ${env.GIT_COMMIT_SHORT} | Tag: ${env.IMAGE_TAG}"
          echo "Frontend workspace host dir: ${env.FE_WORKSPACE_HOST_DIR}"
        }
      }
    }

    stage('Resolve Deploy Target') {
      steps {
        script {
          env.VPS_SSH_HOST = sh(returnStdout: true, script: 'printf "%s" "${HEALYTICS_VPS_HOST:-}"').trim()
          env.VPS_SSH_USER = sh(returnStdout: true, script: 'printf "%s" "${HEALYTICS_VPS_SSH_USER:-deploy}"').trim()

          if (!env.VPS_SSH_HOST) {
            error('Set HEALYTICS_VPS_HOST in the local Jenkins agent environment before deploying.')
          }
        }
      }
    }

    stage('Test') {
      steps {
        // Run tests inside an ephemeral Flutter container (sibling container via host docker.sock).
        // A named volume overlays .pub-cache so we don't re-download packages every build.
        // The entire healytic_fe/ workspace is mounted so admin_panel can resolve ../common.
        sh '''
          set -eu
          docker run --rm \
            -v "${FE_WORKSPACE_HOST_DIR}:/app" \
            -v healytics_panel_pub_cache:/root/.pub-cache \
            -w /app/admin_panel \
            "${FLUTTER_IMAGE}" \
            sh -c '
              flutter pub get &&
              flutter analyze --no-fatal-infos &&
              flutter test
            '
        '''
      }
    }

    stage('Build') {
      steps {
        // Step 1: Build Flutter web inside an ephemeral container.
        // The build output lands on the host at healytic_fe/admin_panel/build/web/.
        sh '''
          set -eu
          docker run --rm \
            -v "${FE_WORKSPACE_HOST_DIR}:/app" \
            -v healytics_panel_pub_cache:/root/.pub-cache \
            -w /app/admin_panel \
            "${FLUTTER_IMAGE}" \
            sh -c '
              flutter pub get &&
              flutter build web --release --wasm --dart-define=ENV=prod --base-href /
            '
        '''

        // Step 2: Package the pre-built web assets into an Nginx Docker image.
        // Uses the multi-stage Dockerfile at healytic_fe/admin_panel/Dockerfile
        // (only the 'runtime' stage — the Flutter build already happened above).
        dir('healytic_fe') {
          sh '''
            set -eu
            docker build \
              -f admin_panel/Dockerfile \
              --target runtime \
              -t "${PANEL_IMAGE}:${IMAGE_TAG}" \
              .
          '''
        }
      }
    }

    stage('Push') {
      steps {
        // Reuse the same docker-push.sh pattern as the backend pipeline.
        // The script loads Docker Hub credentials from .env and pushes the image.
        dir('healytic_fe/admin_panel') {
          sh "../../backend/scripts/docker-push.sh ${IMAGE_TAG} ${PANEL_IMAGE}"
        }
      }
    }

    stage('Deploy VPS') {
      steps {
        sh '''
          set -eu
          ssh -o BatchMode=yes "${VPS_SSH_USER}@${VPS_SSH_HOST}" \
            "PANEL_IMAGE='${PANEL_IMAGE}' '${VPS_DEPLOY_SCRIPT}' '${IMAGE_TAG}'"
        '''
      }
    }
  }

  post {
    success {
      echo "Deployed ${PANEL_IMAGE}:${IMAGE_TAG}"
    }
  }
}
