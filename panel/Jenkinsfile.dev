pipeline {
  agent { label 'local-docker-builder' }

  options {
    skipDefaultCheckout(true)
    disableConcurrentBuilds()
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  // Trigger: Generic Webhook Trigger (configured in casc.yml)
  // GitHub push → Cloudflare Tunnel → Jenkins → injects GIT_REF

  environment {
    PANEL_IMAGE = 'nonameaaaa/healytics_panel_dev'
    // Pinned Flutter SDK version — must match the Dockerfile's build stage.
    FLUTTER_IMAGE = 'ghcr.io/cirruslabs/flutter:3.35.5'
    VPS_DEPLOY_SCRIPT = '/root/dockers/scripts/deploy-panel.sh'
    // Build with dev environment configuration.
    BUILD_ENV = 'dev'
  }

  stages {
    // The host source tree is bind-mounted into the workspace by docker-compose
    // (HEALYTICS_REPO_PATH → /home/jenkins/agent/workspace/healytics-panel).
    // No git clone needed — just read metadata from the existing repo.
    stage('Prepare') {
      steps {
        script {
          def ref = env.GIT_REF ?: 'refs/heads/main'
          env.ACTIVE_BRANCH = ref.replaceFirst(/^refs\/heads\//, '')

          // Read commit SHA from the mounted git repo
          env.GIT_COMMIT_SHORT = sh(
            returnStdout: true,
            script: 'git rev-parse --short=12 HEAD'
          ).trim()

          env.IMAGE_TAG = env.GIT_COMMIT_SHORT

          // Host-side path for docker-run volume mounts (resolved by Docker daemon).
          // HEALYTICS_REPO_PATH is injected by docker-compose.
          // Mount the entire healytic_fe workspace so admin_panel can resolve
          // its path dependency on ../common (Dart workspace layout).
          env.FE_WORKSPACE_HOST_DIR = "${env.HEALYTICS_REPO_PATH}/healytic_fe"

          echo "Branch: ${env.ACTIVE_BRANCH} | Commit: ${env.GIT_COMMIT_SHORT} | Tag: ${env.IMAGE_TAG}"
          echo "Frontend workspace host dir: ${env.FE_WORKSPACE_HOST_DIR}"
          echo "Build ENV: ${BUILD_ENV}"
        }
      }
    }

    stage('Resolve Deploy Target') {
      steps {
        script {
          env.VPS_SSH_HOST = sh(returnStdout: true, script: 'printf "%s" "${HEALYTICS_VPS_HOST:-}"').trim()
          env.VPS_SSH_USER = sh(returnStdout: true, script: 'printf "%s" "${HEALYTICS_VPS_SSH_USER:-deploy}"').trim()

          if (!env.VPS_SSH_HOST) {
            error('Set HEALYTICS_VPS_HOST in the local Jenkins agent environment before deploying.')
          }
        }
      }
    }

    stage('Build') {
      steps {
        // Build with --env dev so the Flutter app uses store.dev.json config.
        dir('healytic_fe/admin_panel') {
          sh "bash scripts/docker-build.sh ${IMAGE_TAG} ${PANEL_IMAGE} --env ${BUILD_ENV}"
        }
      }
    }

    stage('Push') {
      steps {
        dir('healytic_fe/admin_panel') {
          sh "bash scripts/docker-push.sh ${IMAGE_TAG} ${PANEL_IMAGE}"
        }
      }
    }

    stage('Deploy VPS') {
      steps {
        // Pass PANEL_IMAGE override so deploy-panel.sh pulls
        // the dev image instead of the default prod one.
        sh """
          set -eu
          ssh -o BatchMode=yes \
              -o StrictHostKeyChecking=accept-new \
              -o ConnectTimeout=10 \
              ${VPS_SSH_USER}@${VPS_SSH_HOST} \
              'PANEL_IMAGE=${PANEL_IMAGE} PANEL_PROFILE=panel-dev ${VPS_DEPLOY_SCRIPT} ${IMAGE_TAG}'
        """
      }
    }
  }

  post {
    success {
      echo "Deployed ${PANEL_IMAGE}:${IMAGE_TAG} (dev)"
    }
  }
}
